# Twitter/X API v2 Credentials
# Obtain from https://developer.x.com/
TWITTER_BEARER_TOKEN=your_bearer_token_here

# PostgreSQL Database (local instance)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=twitter_data
DB_USER=postgres
DB_PASSWORD=your_password

# Pipeline Configuration
TARGET_TWEET_COUNT=500000
BATCH_SIZE=100
MAX_RESULTS=100

# Rate Limiting (adjust based on your X API tier)
# Basic: ~60 requests per 15 min, Pro: ~300
REQUESTS_PER_WINDOW=60
RATE_LIMIT_WINDOW_SEC=900
RETRY_DELAY_SEC=60
MAX_RETRIES=5

# Search query for tweet collection
# Examples: "cryptocurrency OR bitcoin", "lang:en -is:retweet"
SEARCH_QUERY=lang:en -is:retweet -is:reply

# Checkpoint file for resume capability
CHECKPOINT_FILE=pipeline_checkpoint.json

# USPTO Pipeline (PatentsView)
USPTO_DB_NAME=uspto_data
USPTO_DATA_DIR=uspto_data_downloads
USPTO_BATCH_SIZE=25000
# Row limits - set to 0 for full load. 10k patents ~10 min in quick mode.
# For ~10M patent load: USPTO_MAX_PATENTS=10000000, USPTO_QUICK_MODE=0
USPTO_MAX_PATENTS=10000
USPTO_MAX_INVENTORS=50000
USPTO_MAX_ASSIGNEES=25000
# Quick mode: 1 = only patents+applications (~10 min). 0 = full load (2-5 hrs)
USPTO_QUICK_MODE=1
# Force re-download for scheduled updates (run_uspto_update.py sets this)
USPTO_FORCE_REFRESH=0
