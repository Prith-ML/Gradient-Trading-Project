# Twitter/X API v2 Credentials
# Obtain from https://developer.x.com/
TWITTER_BEARER_TOKEN=your_bearer_token_here

# PostgreSQL Database (local instance)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=twitter_data
DB_USER=postgres
DB_PASSWORD=your_password

# Pipeline Configuration
TARGET_TWEET_COUNT=500000
BATCH_SIZE=100
MAX_RESULTS=100

# Rate Limiting (adjust based on your X API tier)
# Basic: ~60 requests per 15 min, Pro: ~300
REQUESTS_PER_WINDOW=60
RATE_LIMIT_WINDOW_SEC=900
RETRY_DELAY_SEC=60
MAX_RETRIES=5

# Search query for tweet collection
# Examples: "cryptocurrency OR bitcoin", "lang:en -is:retweet"
SEARCH_QUERY=lang:en -is:retweet -is:reply

# Checkpoint file for resume capability
CHECKPOINT_FILE=pipeline_checkpoint.json
